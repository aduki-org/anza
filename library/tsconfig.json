{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@adukiorg/anza": ["./types/index.d.ts"],
      "@adukiorg/anza/api": ["./types/core/api/index.d.ts"],
      "@adukiorg/anza/state": ["./types/core/state/index.d.ts"],
      "@adukiorg/anza/events": ["./types/core/events/index.d.ts"],
      "@adukiorg/anza/router": ["./types/core/router/index.d.ts"],
      "@adukiorg/anza/storage": ["./types/core/storage/index.d.ts"],
      "@adukiorg/anza/offline": ["./types/core/offline/index.d.ts"],
      "@adukiorg/anza/animations": ["./types/core/animations/index.d.ts"],
      "@adukiorg/anza/workers": ["./types/core/workers/index.d.ts"],
      "@adukiorg/anza/security": ["./types/core/security/index.d.ts"],
      "@adukiorg/anza/platform": ["./types/core/platform/index.d.ts"],
      "@adukiorg/anza/ui": ["./types/core/ui/index.d.ts"],
      "@adukiorg/anza/elements": ["./types/elements/index.d.ts"]
    }
  },
  "include": [
    "types/**/*",
    "tests/types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
